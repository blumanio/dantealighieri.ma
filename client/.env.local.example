# ── Resend — transactional email ──────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# ── Owner notifications ────────────────────────────────────────────────────────
# Email address that receives new-lead alerts
# Defaults to med@studentitaly.it if not set
OWNER_EMAIL=

# ── Weather widget (optional) ──────────────────────────────────────────────────
# Get from https://www.weatherapi.com — free tier is sufficient
# If absent, city pages show "Weather unavailable" gracefully (no crash)
NEXT_PUBLIC_WEATHER_API_KEY=
